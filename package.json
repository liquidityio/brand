{
  "name": "@liquidityio/brand",
  "version": "3.0.0",
  "description": "Org config, theme seeds, and assets for Liquidity",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./brand.json": "./src/brand.json",
    "./tw-liquidity.css": "./src/tw-liquidity.css",
    "./assets/*": "./assets/*"
  },
  "files": [
    "src",
    "assets"
  ],
  "scripts": {
    "tc": "tsc --noEmit",
    "prebuild": "generate-palettes",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "pub": "./scripts/publish.sh"
  },
  "dependencies": {
    "@hanzo/branding": "^3.0.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "author": "Liquidity",
  "repository": {
    "type": "git",
    "url": "https://github.com/liquidityio/brand"
  },
  "publishConfig": {
    "access": "public"
  }
}
