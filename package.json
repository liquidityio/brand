{
  "name": "@liquidityio/brand",
  "version": "5.1.0",
  "description": "Org config, theme seeds, and assets for Liquidity",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./liquidity-tw.css": "./src/liquidity-tw.css",
    "./assets/*": "./assets/*"
  },
  "files": [
    "src",
    "assets"
  ],
  "scripts": {
    "tc": "tsc --noEmit",
    "prebuild": "generate-palettes --brandFile src/themes.json",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "pub": "./scripts/publish.sh",
    "ver": "npm view @liquidityio/brand"
  },
  "dependencies": {
    "@hanzo/theming": "^6.0.1"
  },
  "peerDependencies": {
    "@hanzogui/animations-react-native": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "@hanzogui/config-default": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "@hanzogui/shorthands": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "@hanzogui/theme-builder": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "@hanzogui/web": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "hanzogui": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "react": ">=18",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "author": "Liquidity",
  "repository": {
    "type": "git",
    "url": "https://github.com/liquidityio/brand"
  },
  "publishConfig": {
    "access": "public"
  }
}
