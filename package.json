{
  "name": "@liquidityio/brand",
  "version": "1.0.0",
  "description": "Brand assets and configuration for Liquidity",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./brand.json": "./brand.json",
    "./loader": {
      "import": "./dist/loader.mjs",
      "require": "./dist/loader.js",
      "types": "./dist/loader.d.ts"
    },
    "./assets/*": "./assets/*"
  },
  "files": [
    "dist",
    "assets",
    "brand.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/loader.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/loader.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "author": "Liquidity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liquidityio/brand"
  },
  "publishConfig": {
    "access": "public"
  }
}