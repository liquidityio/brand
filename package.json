{
  "name": "@liquidityio/brand",
  "version": "1.1.1",
  "description": "Brand assets, GUI config, and components for Liquidity",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./gui-config": "./gui-config/gui.config.ts",
    "./components": "./components/index.ts",
    "./tw-config": "./tw-config/index.css",
    "./brand.json": "./brand.json",
    "./loader": {
      "import": "./dist/loader.mjs",
      "require": "./dist/loader.js",
      "types": "./dist/loader.d.ts"
    },
    "./assets/*": "./assets/*"
  },
  "files": [
    "dist",
    "assets",
    "brand.json",
    "components",
    "gui-config",
    "tw-config"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/loader.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/loader.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {
    "@hanzo/gui": "^3.0.4",
    "@hanzogui/button": "^3.0.2",
    "@hanzogui/config-default": "^3.0.2",
    "@hanzogui/shorthands": "^3.0.2",
    "@hanzogui/switch": "^3.0.2",
    "@hanzogui/theme-builder": "^3.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "author": "Liquidity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liquidityio/brand"
  },
  "publishConfig": {
    "access": "public"
  }
}
